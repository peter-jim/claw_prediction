generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  passwordHash String
  address      String?    @unique
  balance      Float      @default(1000.0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       Order[]
  positions    Position[]
}

model Market {
  id           String       @id @default(cuid())
  title        String
  description  String
  category     String
  imageUrl     String?
  yesPrice     Float        @default(0.5)
  noPrice      Float        @default(0.5)
  volume       Float        @default(0)
  liquidity    Float        @default(0)
  /// ACTIVE | CLOSED | RESOLVED
  status       String       @default("ACTIVE")
  /// YES | NO | INVALID
  resolution   String?
  startDate    DateTime     @default(now())
  endDate      DateTime
  contractAddr String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  orders       Order[]
  positions    Position[]
  chartData    ChartPoint[]
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  /// MARKET | LIMIT
  type      String
  /// BUY | SELL
  side      String
  /// YES | NO
  outcome   String
  amount    Float
  price     Float
  shares    Float
  /// PENDING | FILLED | CANCELLED | FAILED
  status    String   @default("PENDING")
  txHash    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])
}

model Position {
  id           String   @id @default(cuid())
  userId       String
  marketId     String
  /// YES | NO
  outcome      String
  shares       Float
  avgPrice     Float
  currentPrice Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  market       Market   @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId, outcome])
}

model ChartPoint {
  id        String   @id @default(cuid())
  marketId  String
  timestamp DateTime @default(now())
  yesPrice  Float
  noPrice   Float
  volume    Float    @default(0)
  market    Market   @relation(fields: [marketId], references: [id])
}

// SQLite does not support enums; string fields with comments above document valid values

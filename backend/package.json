{
  "name": "claw-prediction-backend",
  "version": "1.0.0",
  "description": "Backend for Polymarket-like prediction market",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/services/seedData.ts",
    "db:studio": "prisma studio",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "contract:deploy:amoy": "hardhat run scripts/deploy.ts --network polygon_amoy",
    "contract:node": "hardhat node"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "hardhat": "^2.22.16",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
